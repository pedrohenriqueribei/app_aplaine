rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOrgMember(orgId) { return isSignedIn() && (exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)) || isAdmin()); }
    
    match /admins/{adminId} { allow read: if isSignedIn(); }
    match /users/{userId} { allow get: if isSignedIn(); allow write: if isSignedIn() && request.auth.uid == userId; }
    
    match /organizations/{orgId} {
      allow get: if isOrgMember(orgId);
      allow create: if isSignedIn();
      allow update: if isOrgMember(orgId) && (get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'ADMIN' || isAdmin());
      allow delete: if isAdmin();
      match /members/{memberId} { allow read: if isOrgMember(orgId); allow write: if isSignedIn(); }
      match /songs/{songId} { allow read, write: if isOrgMember(orgId); }
      match /events/{eventId} { allow read, write: if isOrgMember(orgId); }
      match /messages/{msgId} { allow read, write: if isOrgMember(orgId); }
    }
  }
}
